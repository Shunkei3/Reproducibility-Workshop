@article{Hamie.etal2026,
  title = {{{AgroSat}}: A Precision Farming Tool for Managing in-Field Variation of Optimal Input Rates and Supporting Agronomic Decisions},
  shorttitle = {{{AgroSat}}},
  author = {Hamie, Najwane and Dainelli, Riccardo and Rocchi, Leandro and Matese, Alessandro and Di Gennaro, Salvatore Filippo and Redwan, Mirvat and Toscano, Piero},
  year = 2026,
  month = aug,
  journal = {Smart Agricultural Technology},
  volume = {14},
  pages = {102044},
  issn = {2772-3755},
  doi = {10.1016/j.atech.2026.102044},
  urldate = {2026-03-30},
  abstract = {AgroSat is a free web-based platform aimed at providing users with a precise data-driven tool for managing key agricultural operations. This decision support system (DSS), mainly dedicated to arable crops, has a user-friendly interface designed to facilitate the adoption of digital agriculture by researchers and end-user farmers. The platform uses publicly available and continuously updated satellite imagery (Sentinel-2 and MODIS), global gridded climatic data (Copernicus Climate Data Store), regional agrometeorological data repository (OpenData), and georeferenced data to provide cost-efficient operational services at field level and support research-oriented applications. Integrating multi-source data, AgroSat allows monitoring crop phenology, water status, vegetation index, and weather forecasts. Moreover, it further supports decision-making through generating downloadable output spatial products, such as yield potential and input prescription maps. The present research aims to introduce the products and services of AgroSat platform, highlighting its application for nitrogen (N) fertilization based on variable rate technology (VRT) through a case study on winter wheat. Research results summarized the potential of AgroSat as an accurate input management tool for generating zonal N prescription maps and stabilizing within-field yield and crop vigor, supporting the overall crop performance and resource use efficiency. Future platform improvements aim to further support sustainable farming practices through additional services, such as soil organic carbon estimation and proposing new strategies for accurate input management.},
  keywords = {Climatic data,DSS,Open data,Prescription maps,Satellite imagery,VRT},
  file = {/Users/shunkeikakimoto/Zotero/storage/VIVDJPXW/Hamie et al. - 2026 - AgroSat a precision farming tool for managing in-field variation of optimal input rates and support.pdf;/Users/shunkeikakimoto/Zotero/storage/TIEFU556/S2772375526002674.html}
}

